# =====================================
# Frontend Configuration
# =====================================

# n8n Webhook URL (where frontend sends requests)
# For local development: http://localhost:5678/webhook/sentiment
# For n8n Cloud: https://your-instance.app.n8n.cloud/webhook/sentiment
VITE_N8N_WEBHOOK_URL=http://localhost:5678/webhook/sentiment


# =====================================
# Backend Configuration (Set in n8n)
# =====================================
# These are set INSIDE n8n (not here):
#
# GROQ_API_KEY=gsk_your_groq_api_key_here
#
# How to set:
# 1. Get free API key from: https://console.groq.com/keys
# 2. In n8n: Settings → Variables → Add Variable
#    Name: GROQ_API_KEY
#    Value: your_groq_key
# 3. Or set as environment variable when running n8n
